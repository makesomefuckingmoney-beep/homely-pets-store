# Stripe keys — https://dashboard.stripe.com/apikeys
# Test mode: sk_test_... and pk_test_...
# Live mode:  sk_live_... and pk_live_...
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Your public website URL (no trailing slash)
# Local: http://localhost:4242
# Live (GoDaddy): https://www.homelypets.co.uk
SITE_URL=http://localhost:4242

# Your GoDaddy domain — see GODADDY-DNS.md
DOMAIN=homelypets.co.uk
PRIMARY_URL=https://www.homelypets.co.uk

PORT=4242

# Optional — Stripe webhook for production order sync
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Purchase alerts (pick one or more) — see NOTIFY.md ──

# Pushover phone app (recommended)
# PUSHOVER_USER_KEY=
# PUSHOVER_APP_TOKEN=

# Telegram bot (free)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Discord or Slack
# DISCORD_WEBHOOK_URL=
# SLACK_WEBHOOK_URL=

# Generic JSON webhook
# NOTIFY_WEBHOOK_URL=

# Secret for POST /api/notify/test
# NOTIFY_ADMIN_SECRET=choose-a-long-random-string
